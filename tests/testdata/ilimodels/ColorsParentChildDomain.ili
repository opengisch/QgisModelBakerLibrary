INTERLIS 2.3;

MODEL Colors (es)
AT "mailto:PC-1@localhost"
VERSION "2020-08-26"  =

  DOMAIN

    DomBaseColorClasss = (
      Green,
      Red,
      Blue
    );

    DomChildColors
    EXTENDS DomBaseColorClasss = (
      Blue(
        Dark_Blue,
        Light_Blue,
        Medium_Blue
      )
    );

  TOPIC Colors =

    CLASS BaseColorClass (ABSTRACT) =
      Colors : Colors.DomBaseColorClasss;
    END BaseColorClass;

    CLASS ChildColor
    EXTENDS BaseColorClass =
      Colors (EXTENDED) : Colors.DomChildColors;
    END ChildColor;

  END Colors;

END Colors.
